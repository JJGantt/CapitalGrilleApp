 {"id":"kb-knights-bridge-chardonnay","primary_area":"Right Cooler","primary_column":5,"backup_area":null,"backup_column":null,"updated":"2026-05-26T12:02:34","kind":"wine","name":"KB by Knight's Bridge, Chardonnay","deleted":false,"readonly":false,"primary_row":2,"backup_row":null,"category":"White Wine","tasting_notes":"The nose is complex, forward and pure with hints of stone fruit, grilled almonds, Meyer lemon and toasted oak. On the palate the wine delivers the perfect balance of flavor, richness and structure.","food_pairing":"Rich seafood, roasted chicken, & creamy or nut-accented dishes","image_url":"https://felyggqjjhltwokdfhop.supabase.co/storage/v1/object/public/wine-bottles/kb-knights-bridge-chardonnay.jpg"}, 
